# ── Application ────────────────────────────────────────────────
APP_ENV=development          # development | production
SECRET_KEY=change_me_in_prod
LOG_LEVEL=INFO

# ── Database ────────────────────────────────────────────────────
DATABASE_URL=postgresql://devlife:devlife@localhost:5432/devlife_hub
# Alternative SQLite pour le dev local (commenter PostgreSQL ci-dessus)
# DATABASE_URL=sqlite:///./devlife.db

# ── AWS S3 (stockage raw data) ──────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=eu-west-3
S3_BUCKET_RAW=devlife-hub-raw
S3_BUCKET_MODELS=devlife-hub-models

# ── MLflow ──────────────────────────────────────────────────────
MLFLOW_TRACKING_URI=http://localhost:5000
# En prod : MLFLOW_TRACKING_URI=https://ton-serveur-mlflow

# ── Weather API ─────────────────────────────────────────────────
OPENWEATHER_API_KEY=
LOCATION_LAT=46.1453          # Saint-Julien-en-Genevois
LOCATION_LON=6.0806
LOCATION_NAME=Saint-Julien-en-Genevois

# ── Telegram Bot (optionnel) ────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Claude API (module coach) ───────────────────────────────────
ANTHROPIC_API_KEY=

# ── Samsung Health ──────────────────────────────────────────────
SAMSUNG_HEALTH_EXPORT_DIR=data/exports/samsung_health

# ── Prefect (orchestration) ─────────────────────────────────────
PREFECT_API_URL=http://localhost:4200/api
